"Total_Games", "Debut_Year_Games", "Three_Year_Games",
"TD_INT", "Debut_TD_INT", "Three_Year_TD_INT",
"RUN_PASS", "Debut_RUN_PASS", "Three_Year_RUN_PASS",
"Completion_Percentage", "Debut_Completion_Percentage",
"Three_Year_Completion_Percentage",
"Yards_per_game", "Debut_Yards_per_game", "Three_Year_Yards_per_game",
"Sacks_per_game", "Debut_Sacks_per_game", "Three_Year_Sacks_per_game",
"TD_per_game", "Debut_TD_per_game", "Three_Year_TD_per_game",
"Ints_per_game", "Debut_Ints_per_game", "Three_Year_Ints_per_game",
